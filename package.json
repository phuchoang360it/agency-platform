{
  "name": "agency-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:types": "node --import tsx node_modules/payload/bin.js generate:types",
    "generate:importmap": "node --import tsx node_modules/payload/bin.js generate:importmap",
    "migrate:create": "node --import tsx node_modules/payload/bin.js migrate:create",
    "migrate": "node --import tsx node_modules/payload/bin.js migrate",
    "tenant:seed": "tsx scripts/tenant-seed.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/plugin-multi-tenant": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-s3": "^3.0.0",
    "next": "^16.2.2",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@next/env@15.5.18": "patches/@next__env@15.5.18.patch"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@img/sharp-win32-x64",
      "@img/sharp-linux-x64",
      "@img/sharp-darwin-arm64"
    ]
  },
  "devDependencies": {
    "@next/env": "^16.2.6",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
